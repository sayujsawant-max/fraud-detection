# ============================================================
# FraudShield MLOps — Frontend environment
# Copy to .env.local and adjust before `npm run dev`.
# ============================================================

# Base URL of the FraudShield FastAPI backend.
# - In Docker Compose the API is mapped to host port 8001 (8001 → 8000).
# - Running `npm run dev` against `make dev` (port 8000) → use port 8000.
NEXT_PUBLIC_API_URL=http://localhost:8001
