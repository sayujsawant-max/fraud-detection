# ============================================================
# FraudShield MLOps — Production environment template
# ============================================================
# Copy to ``.env.production`` (kept out of git) on the deployment host and
# fill in the real values. Every field is required for a public deploy.
# Local development should use ``.env.example`` instead — that one ships
# safe defaults that work against Docker Compose.

# ---------- Database (Phase 4) ----------
# Async SQLAlchemy URL. Use the *internal* URL from your managed Postgres
# provider (Render / Neon / Supabase) — the API does not need a public
# DB endpoint.
DATABASE_URL=

# ---------- MLflow (Phase 2) ----------
MLFLOW_TRACKING_URI=
MLFLOW_MODEL_NAME=fraud-detector
MLFLOW_MODEL_STAGE=Production

# ---------- API security (Phase 6) ----------
# Random 32+ char secret. Used to protect /v1/admin/* endpoints.
# NEVER reuse the local dev "change-me" value in production.
API_KEY=
# Must be false in production. The dummy fallback exists only so the
# stack boots when MLflow is missing for local dev.
ALLOW_DUMMY_MODEL=false

# ---------- Drift (Phase 5) ----------
DRIFT_THRESHOLD=0.30
DRIFT_MIN_SAMPLES=200
DRIFT_LOOKBACK_LIMIT=1000
# Set to a path on persistent disk if your platform supports it; the
# reference parquet must be uploaded once per deploy.
REFERENCE_DATA_PATH=
# Writable directory for Evidently HTML + JSON artifacts.
DRIFT_REPORT_DIR=

# ---------- URLs ----------
# Internal URL the retraining flow uses to call /v1/admin/reload-model
# after a successful promotion. Inside docker-compose this is
# "http://api:8000"; in Render / Vercel it should be the *internal*
# service URL.
API_BASE_URL=
# Public URL the dashboard is served from (used for CORS).
FRONTEND_URL=
# Public API URL inlined into the Next.js bundle at build time.
NEXT_PUBLIC_API_URL=

# ---------- Prefect (Phase 6) ----------
# https://app.prefect.cloud/api/accounts/<id>/workspaces/<id> or your
# self-hosted server. Leave PREFECT_API_KEY blank when self-hosting.
PREFECT_API_URL=
PREFECT_API_KEY=
PREFECT_WORK_POOL=fraudshield-pool

# ---------- Retraining gate (Phase 6) ----------
# Minimum PR-AUC improvement required to promote a challenger. Higher =
# fewer (but more meaningful) promotions in noisy environments.
MODEL_PROMOTION_MIN_DELTA=0.01
