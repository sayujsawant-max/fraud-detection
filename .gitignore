# ============================================================
# FraudShield MLOps — repository ignores
# ============================================================
# Anything we never want to commit goes here. Bias toward over-ignoring
# rather than leaking secrets, parquet datasets, or test caches.

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage/
coverage.xml
*.cover
.tox/
.nox/
.venv/
venv/
env/
ENV/
.python-version

# ---------- Environment / secrets ----------
.env
.env.local
.env.development
.env.staging
.env.production
.env.*.local
*.env
!.env.example
!frontend/.env.example

# ---------- Node / Next.js ----------
node_modules/
.next/
out/
.pnp.*
.yarn/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.turbo/
.vercel/

# ---------- MLflow / ML artifacts ----------
mlruns/
mlartifacts/
*.pkl
*.joblib
*.onnx

# ---------- Data ----------
data/raw/
data/processed/
backend/data/raw/
backend/data/processed/
*.parquet
*.csv
*.feather
*.npz
*.npy
!backend/data/reference/.gitkeep

# ---------- Reports + drift artifacts ----------
backend/reports/
reports/
!backend/reports/.gitkeep

# ---------- Databases / state ----------
*.db
*.sqlite
*.sqlite3
.prefect-test/
.prefect/

# ---------- Docker ----------
*.tar
.docker/

# ---------- IDE ----------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------- Logs ----------
*.log
logs/

# ---------- Misc ----------
.cache/
tmp/
temp/

# ---------- Local TLS certs (corporate proxy bundles) ----------
backend/certs/*.pem
backend/certs/*.crt
frontend/certs/*.pem
frontend/certs/*.crt
!backend/certs/.gitkeep
!frontend/certs/.gitkeep
