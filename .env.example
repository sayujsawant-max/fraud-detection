# ============================================================
# FraudShield MLOps — Environment Variables
# Copy this file to .env and replace values before running.
# Never commit .env.
# ============================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=fraudshield
POSTGRES_PASSWORD=fraudshield_password
POSTGRES_DB=fraudshield_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://fraudshield:fraudshield_password@postgres:5432/fraudshield_db

# ---------- MLflow ----------
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_MODEL_NAME=fraud-detector
MLFLOW_MODEL_STAGE=Production

# ---------- API ----------
API_KEY=change-me

# ---------- Drift (Phase 5) ----------
# Share of drifted feature columns above which we flag the dataset as drifted.
DRIFT_THRESHOLD=0.30
# Below this many prediction logs, the drift check returns status="skipped"
# rather than computing an unreliable report.
DRIFT_MIN_SAMPLES=200
# Default lookback window of most-recent prediction logs to score.
DRIFT_LOOKBACK_LIMIT=1000
# Reference dataset used as the baseline. Relative to project root.
REFERENCE_DATA_PATH=backend/data/reference/reference.parquet
# Where Evidently HTML/JSON reports are written. Relative to project root.
DRIFT_REPORT_DIR=backend/reports/drift
# When true and the MLflow model is missing, the API falls back to a
# deterministic DummyFraudModel so /v1/predict still works in local dev.
# MUST be false in production.
ALLOW_DUMMY_MODEL=true
# Decision threshold used when the model's optimal_threshold.json artifact
# and the run-level metric are both unavailable.
DEFAULT_THRESHOLD=0.5
# Hard cap on transactions per POST /v1/predict/batch call.
MAX_BATCH_SIZE=100

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8001
FRONTEND_URL=http://localhost:3000

# ---------- Prefect (Phase 6) ----------
PREFECT_API_URL=http://prefect:4200/api
# Optional API key for Prefect Cloud or a secured self-hosted server.
PREFECT_API_KEY=
# Work-pool name used by start_prefect_worker.py (optional Option-B path).
PREFECT_WORK_POOL=fraudshield-pool
# Cron schedule for the monitoring flow (every 6 hours by default).
PREFECT_MONITORING_CRON=0 */6 * * *
# Cron schedule for the retraining flow (Sundays at 02:00 by default).
PREFECT_RETRAINING_CRON=0 2 * * 0

# ---------- Retraining (Phase 6) ----------
# Minimum PR-AUC improvement required to promote a challenger over the
# current champion. 0.01 ~ "one percentage point" — keeps noisy retrains
# from flipping the production alias.
MODEL_PROMOTION_MIN_DELTA=0.01
# Internal URL the retraining flow uses to call /v1/admin/reload-model
# after a successful promotion. Use the container alias inside Docker
# and http://localhost:8001 when running the API on the host.
API_BASE_URL=http://api:8000
