# ============================================================
# FraudShield MLOps — Environment Variables
# Copy this file to .env and replace values before running.
# Never commit .env.
# ============================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=fraudshield
POSTGRES_PASSWORD=fraudshield_password
POSTGRES_DB=fraudshield_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://fraudshield:fraudshield_password@postgres:5432/fraudshield_db

# ---------- MLflow ----------
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_MODEL_NAME=fraud-detector
MLFLOW_MODEL_STAGE=Production

# ---------- API ----------
API_KEY=change-me
DRIFT_THRESHOLD=0.30

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ---------- Prefect ----------
PREFECT_API_URL=http://prefect:4200/api
